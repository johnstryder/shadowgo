# ShadowGo environment variables (copy to .env and fill in)
# Never commit .env - it is gitignored

# LLM / Vision (for -screenshot -analyze)
# OPENROUTER_API_KEY=
# SHADOWGO_API_KEY=
# SHADOWGO_LLM_BASE_URL=https://openrouter.ai/api/v1
# SHADOWGO_LLM_MODEL=openai/gpt-4-vision-preview

# X (Twitter) OAuth (for shadowgo login x)
# SHADOWGO_X_CLIENT_ID=
# SHADOWGO_X_CLIENT_SECRET=
# SHADOWGO_X_REDIRECT_URI=http://127.0.0.1:8080/callback

# Optional overrides
# SHADOWGO_OUTPUT_DIR=
# SHADOWGO_SCREENSHOT_DIR=
# SHADOWGO_CONFIG_DIR=
